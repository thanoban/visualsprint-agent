# VisualSprint environment template.
#
# Copy to .env and replace every REPLACE_* placeholder with a real value.
# .env is gitignored — NEVER commit real API keys. In Cloud Run, inject secret
# values with `gcloud run deploy --set-secrets` (see deploy.sh) instead of raw keys.
#
# Non-secret values below (URLs, project ids, region, agent ids, index) are
# pre-filled to match the live configuration. Agents run in us-west1; the
# Elasticsearch project is in us-central1.

# ---------------------------------------------------------------------------
# Shared / Google Cloud
# ---------------------------------------------------------------------------
VISUALSPRINT_ENV=production
VISUALSPRINT_TRACK=elastic
PROJECT_ID=visualsprint-agent
PROJECT_NUMBER=530780341550
REGION=us-west1
VISUALSPRINT_ALLOWED_ORIGINS=https://app.visualsprint.dev,http://localhost:3000

# Secret Manager secret names (created via gcloud; see DEPLOY.md). Not the keys.
ELASTIC_BACKEND_SECRET=elastic-backend-key
ELASTIC_MCP_SECRET=elastic-mcp-key
JIRA_TOKEN_SECRET=jira-api-token
SLACK_TOKEN_SECRET=SLACK_BOT_TOKEN_SECRET

# ---------------------------------------------------------------------------
# services/api  (control plane + Elastic write-back/search + action executors)
# ---------------------------------------------------------------------------
VISUALSPRINT_AGENTS_SERVICE_URL=https://visualsprint-agents-REPLACE.a.run.app
VISUALSPRINT_INGEST_SERVICE_URL=
VISUALSPRINT_MEDIA_SERVICE_URL=

# Elasticsearch DATA endpoint (us-central1):
ELASTICSEARCH_URL=https://my-elasticsearch-project-ad6723.es.us-central1.gcp.elastic.cloud
ELASTIC_INDEX_OUTCOMES=visualsprint-outcomes
# Used DIRECTLY as the `ApiKey` header. Local: paste the Elastic *encoded* backend
# key; Cloud Run: injected from Secret Manager (elastic-backend-key) by deploy.sh.
ELASTICSEARCH_API_KEY=REPLACE_WITH_ELASTIC_BACKEND_ENCODED_KEY
# Kibana Agent Builder MCP endpoint (status surface on the API side):
ELASTIC_MCP_SERVER_URL=https://my-elasticsearch-project-ad6723.kb.us-central1.gcp.elastic.cloud/api/agent_builder/mcp

# Action executors (Jira / Slack) — currently stubbed; fill when wiring real APIs:
JIRA_BASE_URL=
JIRA_API_TOKEN_SECRET=REPLACE_WITH_JIRA_API_TOKEN
SLACK_BOT_TOKEN_SECRET=REPLACE_WITH_SLACK_BOT_TOKEN
SLACK_DEFAULT_CHANNEL=#visualsprint

# ---------------------------------------------------------------------------
# services/agents  (adapter to the managed Gemini/Agent Builder agents, us-west1)
# ---------------------------------------------------------------------------
VISUALSPRINT_AGENT_MODE=configured_cloud
VISUALSPRINT_DEPLOYMENT_TARGET=cloud_run
VISUALSPRINT_AGENT_RUNTIME_BACKEND=vertex_ai_reasoning_engine
VISUALSPRINT_GOOGLE_CLOUD_PROJECT_ID=visualsprint-agent
VISUALSPRINT_GOOGLE_CLOUD_PROJECT_NUMBER=530780341550
VISUALSPRINT_GOOGLE_CLOUD_LOCATION=us-west1
VISUALSPRINT_AGENT_APPLICATION_ID=REPLACE_WITH_AGENT_APP_ID

# Live Reasoning Engine ids (non-secret; from the agents Cloud Run manifest):
VISUALSPRINT_REASONING_AGENT_ID=554162656492126208
VISUALSPRINT_SUMMARY_AGENT_ID=6620511354560184320
VISUALSPRINT_ACTION_AGENT_ID=7293799498852073472
VISUALSPRINT_REASONING_ENGINE_RESOURCE_NAME=projects/530780341550/locations/us-west1/reasoningEngines/554162656492126208
VISUALSPRINT_SUMMARY_ENGINE_RESOURCE_NAME=projects/530780341550/locations/us-west1/reasoningEngines/6620511354560184320
VISUALSPRINT_ACTION_ENGINE_RESOURCE_NAME=projects/530780341550/locations/us-west1/reasoningEngines/7293799498852073472
VISUALSPRINT_REASONING_QUERY_URL=https://us-west1-aiplatform.googleapis.com/v1/projects/530780341550/locations/us-west1/reasoningEngines/554162656492126208:query
VISUALSPRINT_SUMMARY_QUERY_URL=https://us-west1-aiplatform.googleapis.com/v1/projects/530780341550/locations/us-west1/reasoningEngines/6620511354560184320:query
VISUALSPRINT_ACTION_QUERY_URL=https://us-west1-aiplatform.googleapis.com/v1/projects/530780341550/locations/us-west1/reasoningEngines/7293799498852073472:query

# On Cloud Run the service identity token is used automatically; for LOCAL dev
# against vertex paste a short-lived token (gcloud auth print-access-token):
VISUALSPRINT_GOOGLE_API_ACCESS_TOKEN=

VISUALSPRINT_CLOUD_RUN_SERVICE_URL=https://visualsprint-agents-REPLACE.a.run.app
VISUALSPRINT_SERVICE_ACCOUNT_EMAIL=visualsprint-agents@visualsprint-agent.iam.gserviceaccount.com
VISUALSPRINT_AGENT_REQUEST_TIMEOUT_SECONDS=4.0

# Elastic MCP — only needed if the agents service itself calls MCP (Path B).
# If MCP is connected INSIDE the Google agent (Path A), leave the key blank.
VISUALSPRINT_ELASTIC_MCP_ENDPOINT=https://my-elasticsearch-project-ad6723.kb.us-central1.gcp.elastic.cloud/api/agent_builder/mcp
VISUALSPRINT_ELASTIC_API_KEY=REPLACE_WITH_ELASTIC_MCP_ENCODED_KEY

# Control plane URL the ADK persistence tools call back into to write outputs.
# Leave blank to keep ADK persistence tools in safe deferred/no-op mode.
VISUALSPRINT_CONTROL_PLANE_URL=https://visualsprint-api-REPLACE.a.run.app
VISUALSPRINT_CONTROL_PLANE_BEARER_TOKEN=

# Gemini model ids for the ADK agent scaffolds (override as needed):
VISUALSPRINT_REASONING_MODEL=gemini-flash-latest
VISUALSPRINT_SUMMARY_MODEL=gemini-flash-latest
VISUALSPRINT_ACTION_MODEL=gemini-flash-latest
